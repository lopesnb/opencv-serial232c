{
    "tasks": [
        {
    "label": "★パス確認用",
    "type": "shell",
    "command": "echo '現在エディタで開いているのは: ${fileBasename}' && echo 'VS Codeが探しているフルパスは: ${fileDirname}/${fileBasenameNoExtension}'",
    "problemMatcher": []
},
        {
            
            "type": "cppbuild",
            "label": "C/C++: gcc アクティブなファイルのビルド",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "デバッガーによって生成されたタスク。"
 
            
        }
    ],
    "version": "2.0.0"
}